---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Follow AI — AI Coding 最佳实践',
  description = '更直观、更易理解地掌握 AI 编程知识。每个示例都是精心制作的沉浸式网页。',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OG Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><text y='28' font-size='28'>🤖</text></svg>" />

    <style is:global>
      :root {
        /* 品牌渐变 */
        --color-brand-start: #667eea;
        --color-brand-end: #764ba2;

        /* 表面 */
        --color-bg-body: #f5f6fc;
        --color-bg-card: #ffffff;
        --color-bg-chip: #eeedf5;
        --color-bg-chip-alt: #f3f2fa;

        /* 文字 */
        --color-text-primary: #1a1a2e;
        --color-text-heading: #333;
        --color-text-body: #555;
        --color-text-secondary: #666;
        --color-text-muted: #767676;
        --color-text-placeholder: #999;
        --color-text-disabled: #bbb;

        /* 边框 */
        --color-border: #e0e0ea;

        /* 阴影（品牌色调色） */
        --shadow-card: 0 1px 3px rgba(102, 126, 234, 0.06), 0 1px 2px rgba(0, 0, 0, 0.04);
        --shadow-card-hover: 0 8px 25px rgba(102, 126, 234, 0.10), 0 4px 10px rgba(0, 0, 0, 0.04);
      }

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body {
        font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        background-color: var(--color-bg-body);
        background-image:
          radial-gradient(
            ellipse 80% 50% at 50% 0%,
            rgba(102, 126, 234, 0.07) 0%,
            rgba(118, 75, 162, 0.04) 40%,
            transparent 70%
          );
        background-repeat: no-repeat;
        background-size: 100% 800px;
        color: var(--color-text-primary);
        line-height: 1.6;
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
