---
---

<header class="site-header">
  <div class="header-content">
    <h1 class="site-name">All-in-AI</h1>
    <p class="tagline">AI Coding 最佳实践，沉浸式体验</p>
  </div>
</header>

<style>
  .site-header {
    text-align: center;
    padding: 40px 24px 32px;
    max-height: 120px;
  }

  .header-content {
    max-width: 1200px;
    margin: 0 auto;
  }

  .site-name {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .tagline {
    font-size: 1rem;
    color: #666;
    margin-top: 4px;
  }

  @media (max-width: 640px) {
    .site-header {
      padding: 24px 16px 20px;
    }

    .site-name {
      font-size: 1.5rem;
    }

    .tagline {
      font-size: 0.875rem;
    }
  }
</style>
